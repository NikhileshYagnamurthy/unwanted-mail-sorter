{
  "manifest_version": 3,
  "name": "InboxAI — Smart Gmail Organizer",
  "version": "1.0.0",
  "description": "AI-powered inbox cleanup. Automatically labels promotions, newsletters, phishing, and more.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://unwanted-mail-sorter.onrender.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
